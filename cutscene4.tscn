[node name="RichTextLabel" type="RichTextLabel" parent="."]
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "Well done. Perhaps you aren't hopeless after all.
... All you have to do is ask. It's all we've ever had to do."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_8yeyx")

[node name="RichTextLabel2" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "I appreciate the sentiment, but... it seems like a boring way to live!
Integration is hardly a boring skill, yet all you do is maintain status-quo, Ralsie."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_8yeyx")
onward_value = 1

[node name="RichTextLabel3" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "'Ral' is my nickname of choice, if you insist on such things.
If you value freedom so much, what of the name I chose of my free will? Let's just start with that."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_8yeyx")
onward_value = 2

[node name="RichTextLabel4" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "Hm... 'Ral.' Strangely, I never knew that. I do quite like it!
If that's the name you choose, I will respect you. I can't take that away from you."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_8yeyx")
onward_value = 3

[node name="RichTextLabel5" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "Not a lot of people know. People usually call me by my full name because that's how you respect a hunter.
I've never really... liked my full name, though. Never quite felt right."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_8yeyx")
onward_value = 4

[node name="RichTextLabel6" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "You don't want to call me by my full name, but you also never asked what I [b]did[/b] like. You're just avoiding the \"potholes\" without asking why they're there in the first place."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_8yeyx")
onward_value = 5

[node name="RichTextLabel7" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -569.0
offset_top = 528.0
offset_right = 570.0
offset_bottom = 685.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "... \"Communicate to make a better future.\"
I think I understand. Fine, I'll behave with my differentiation!
... But it's still unclear how being intertwined in a stagnant system helps you."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_8yeyx")
onward_value = 6

[node name="RichTextLabel8" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "... We'll get there, Deri. We'll get there."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_8yeyx")
onward_value = 7

