bbcode_enabled = true
text = "Some time later, at a local cafe..."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_n76pn")

[node name="RichTextLabel2" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "Why, drinking tomato juice, of course!
I'm fairly certain I have a right to nutrition, no matter my crimes."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_n76pn")
onward_value = 1

[node name="RichTextLabel3" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "Look- I...
I will not concede on my previous points. You are still a selfish criminal. I am an enactor of justice."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_n76pn")
onward_value = 2

[node name="RichTextLabel4" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "Thus, there must be things done to amend your ways.
... I will give you an offer. Community service under strict supervision.
It's not like your crimes are a point of contention anyway, so we can skip trial."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_n76pn")
onward_value = 3

[node name="RichTextLabel5" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "Hm, that doesn't really sound legal. But I've never paid attention to the law, so how would I know?
I suppose it beats being in a prision cell! What am I to do, Inty?"
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_n76pn")
onward_value = 4

[node name="RichTextLabel6" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "... Don't call me that.
... Anyway, help me clean up your messes with [b]integration[/b]. It's a similar methodology to differentiation, so it shouldn't be too difficult."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_n76pn")
onward_value = 5

[node name="RichTextLabel7" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "I have documents of every single person you've differentiated, so our task is to find those people and see if they want to return to their former selves."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_n76pn")
onward_value = 6

[node name="RichTextLabel8" type="RichTextLabel" parent="."]
visible = false
texture_filter = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -575.0
offset_top = 518.0
offset_right = 564.0
offset_bottom = 675.0
grow_horizontal = 2
theme = SubResource("Theme_s2ta7")
bbcode_enabled = true
text = "You can go try it on those functions over there. Just make sure they know what you're doing before you do it.
If they disagree... uh, you can revert them back."
scroll_active = false
horizontal_alignment = 1
script = ExtResource("5_n76pn")
onward_value = 7

